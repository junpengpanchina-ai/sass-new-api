# 公网 API 主机：api.tokfai.com（Nginx 终止 TLS 后反代本机）
# Vercel 前端：NEXT_PUBLIC_API_BASE_URL=https://api.tokfai.com

NODE_ENV=production
PORT=3000
HOST=127.0.0.1

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

TOKEN_PEPPER=CHANGE_TO_A_LONG_RANDOM_SECRET

# OpenAI-compatible upstream (V1 single upstream)
UPSTREAM_BASE_URL=https://YOUR_UPSTREAM_HOST/v1
UPSTREAM_API_KEY=YOUR_UPSTREAM_API_KEY
UPSTREAM_NAME=grsai-primary

# Optional (later)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GRSAI_API_KEY=
GRSAI_BASE_URL=
