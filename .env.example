# Environment split (production-shaped):
# - Vercel / browser: only NEXT_PUBLIC_* + anon key (+ Stripe publishable if needed).
# - DMIT / server: SUPABASE_SERVICE_ROLE_KEY, STRIPE_*, GRSAI_*, TOKEN_* pepper, webhooks.
# - Supabase DB: business config (plans, upstream flags, models), NOT plaintext platform secrets.
# See docs/architecture.md §「配置与密钥分层」.

# =========================
# Web (apps/web)
# =========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 管理后台请求 DMIT（与 apps/web/src/app/admin/_lib/adminFetch.ts 一致）
NEXT_PUBLIC_DMIT_API_URL=
# 生产设为 true 并重新部署后，可访问 /debug/connectivity 做连通性自检；完成后删除或改 false
NEXT_PUBLIC_ENABLE_CONNECTIVITY_PAGE=
# 生产示例：NEXT_PUBLIC_API_BASE_URL=https://api.tokfai.com
NEXT_PUBLIC_API_BASE_URL=
# 生产示例：NEXT_PUBLIC_SITE_URL=https://tokfai.com
NEXT_PUBLIC_SITE_URL=

# IMPORTANT: service role 只能放服务端（Next Route Handler / Server Action / DMIT）；勿进 Vercel 前端构建
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics (optional, zero-code injection)
GOOGLE_ANALYTICS_ID=
UMAMI_WEBSITE_ID=
# If you use Umami Cloud, you can leave this empty (defaults to official script URL)
UMAMI_SCRIPT_URL=

# =========================
# Gateway (apps/gateway)
# =========================
GATEWAY_PORT=8000

# Profiling (optional)
ENABLE_PPROF=false
PYROSCOPE_URL=
PYROSCOPE_APP_NAME=
PYROSCOPE_BASIC_AUTH_USER=
PYROSCOPE_BASIC_AUTH_PASSWORD=
PYROSCOPE_MUTEX_RATE=
PYROSCOPE_BLOCK_RATE=
HOSTNAME=

# Upstream (V1 可先接朋友上游)
UPSTREAM_KIND=openai_compatible
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=

# Gateway dev auth (core chain first)
# Comma-separated plaintext tokens for local testing. Example: "dev_token_1,dev_token_2"
DEV_TOKENS=

# Token hashing / signing
TOKEN_HASH_PEPPER=

# Supabase (gateway 用 service role 读写 tokens/logs)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# DB-driven upstream config (gateway)
UPSTREAM_CACHE_TTL_SECONDS=30
UPSTREAM_SECRET_KEY=

