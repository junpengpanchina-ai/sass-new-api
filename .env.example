# =========================
# Web (apps/web)
# =========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# IMPORTANT: service role 只能放服务端（Next Route Handler / Server Action）
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Analytics (optional, zero-code injection)
GOOGLE_ANALYTICS_ID=
UMAMI_WEBSITE_ID=
# If you use Umami Cloud, you can leave this empty (defaults to official script URL)
UMAMI_SCRIPT_URL=

# =========================
# Gateway (apps/gateway)
# =========================
GATEWAY_PORT=8000

# Profiling (optional)
ENABLE_PPROF=false
PYROSCOPE_URL=
PYROSCOPE_APP_NAME=
PYROSCOPE_BASIC_AUTH_USER=
PYROSCOPE_BASIC_AUTH_PASSWORD=
PYROSCOPE_MUTEX_RATE=
PYROSCOPE_BLOCK_RATE=
HOSTNAME=

# Upstream (V1 可先接朋友上游)
UPSTREAM_KIND=openai_compatible
UPSTREAM_BASE_URL=
UPSTREAM_API_KEY=

# Gateway dev auth (core chain first)
# Comma-separated plaintext tokens for local testing. Example: "dev_token_1,dev_token_2"
DEV_TOKENS=

# Token hashing / signing
TOKEN_HASH_PEPPER=

# Supabase (gateway 用 service role 读写 tokens/logs)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# DB-driven upstream config (gateway)
UPSTREAM_CACHE_TTL_SECONDS=30
UPSTREAM_SECRET_KEY=

